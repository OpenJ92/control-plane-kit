import hashlib
import hmac
import json
import os
import threading
import time
from collections import deque
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.error import HTTPError, URLError
from urllib.parse import parse_qs, urlsplit
from urllib.request import HTTPRedirectHandler, Request, build_opener

TARGET = os.environ["LOGGER_TARGET_URL"].rstrip("/")
CONTROL_TOKEN = os.environ["CPK_CONTROL_TOKEN"]
CAPACITY = {{ capacity }}
PAGE_LIMIT = {{ page_limit }}
UPSTREAM_TIMEOUT_SECONDS = {{ upstream_timeout_ms }} / 1000
MAX_REQUEST_BYTES = {{ max_request_bytes }}
MAX_RESPONSE_BYTES = {{ max_response_bytes }}
HASH_PATHS = {{ hash_paths }}
LOCK = threading.Lock()
EVIDENCE = deque(maxlen=CAPACITY)
SEQUENCE = 0
EVICTED = 0


class NoRedirects(HTTPRedirectHandler):
    def redirect_request(self, request, file_pointer, code, message, headers, new_url):
        return None


OPENER = build_opener(NoRedirects)


def method_name(value):
    upper = value.upper()
    return upper if upper in {"GET", "HEAD", "OPTIONS", "POST", "PUT", "PATCH", "DELETE"} else "OTHER"


def status_class(status):
    if status < 200:
        return "informational"
    if status < 300:
        return "success"
    if status < 400:
        return "redirection"
    if status < 500:
        return "client-error"
    return "server-error"


def path_digest(path):
    return hashlib.sha256(path.encode()).hexdigest() if HASH_PATHS else None


def record(method, path, status, duration_ms, request_bytes, response_bytes):
    global SEQUENCE, EVICTED
    with LOCK:
        SEQUENCE += 1
        if len(EVIDENCE) == CAPACITY:
            EVICTED += 1
        item = {
            "sequence": SEQUENCE,
            "correlation_id": f"traffic-{SEQUENCE:020d}",
            "method": method_name(method),
            "status_class": status_class(status),
            "duration_ms": duration_ms,
            "request_bytes": request_bytes,
            "response_bytes": response_bytes,
        }
        digest = path_digest(path)
        if digest is not None:
            item["path_digest"] = digest
        EVIDENCE.append(item)


def page(offset, limit):
    with LOCK:
        values = list(EVIDENCE)
        return {
            "offset": offset,
            "limit": limit,
            "total": len(values),
            "evicted": EVICTED,
            "items": values[offset:offset + limit],
        }


class Handler(BaseHTTPRequestHandler):
    def _json(self, status, payload):
        body = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode()
        self.send_response(status)
        self.send_header("content-type", "application/json")
        self.send_header("content-length", str(len(body)))
        self.end_headers()
        if self.command != "HEAD":
            self.wfile.write(body)

    def _authorized(self):
        authorization = self.headers.get("authorization", "")
        alternate = self.headers.get("x-control-plane-token", "")
        return hmac.compare_digest(authorization, f"Bearer {CONTROL_TOKEN}") or hmac.compare_digest(alternate, CONTROL_TOKEN)

    def _read_logs(self):
        if not self._authorized():
            self._json(401, {"detail": "unauthorized"})
            return
        query = parse_qs(urlsplit(self.path).query, keep_blank_values=True)
        try:
            offset = int(query.get("offset", ["0"])[0])
            limit = int(query.get("limit", [str(PAGE_LIMIT)])[0])
        except ValueError:
            self._json(400, {"detail": "invalid pagination"})
            return
        if offset < 0 or offset > CAPACITY or limit < 1 or limit > PAGE_LIMIT:
            self._json(400, {"detail": "invalid pagination"})
            return
        self._json(200, page(offset, limit))

    def _read_body(self):
        try:
            length = int(self.headers.get("content-length", "0") or "0")
        except ValueError:
            return None, 400
        if length < 0 or length > MAX_REQUEST_BYTES:
            return None, 413
        self.connection.settimeout(UPSTREAM_TIMEOUT_SECONDS)
        return self.rfile.read(length), None

    def _forward(self):
        body, error_status = self._read_body()
        started = time.monotonic()
        if error_status is not None:
            payload = b"invalid or oversized request"
            record(self.command, self.path.split("?", 1)[0], error_status, 0, 0, len(payload))
            self.send_response(error_status)
            self.send_header("content-length", str(len(payload)))
            self.end_headers()
            if self.command != "HEAD":
                self.wfile.write(payload)
            return
        request_headers = {
            key.lower(): value
            for key, value in self.headers.items()
            if key.lower() not in {"host", "content-length"}
        }
        request = Request(
            TARGET + self.path,
            data=body or None,
            headers=request_headers,
            method=self.command,
        )
        try:
            response = OPENER.open(request, timeout=UPSTREAM_TIMEOUT_SECONDS)
            with response:
                payload = response.read(MAX_RESPONSE_BYTES + 1)
                status = response.status
                response_headers = tuple(response.headers.items())
        except HTTPError as error:
            with error:
                payload = error.read(MAX_RESPONSE_BYTES + 1)
                status = error.code
                response_headers = tuple(error.headers.items())
        except (OSError, TimeoutError, URLError):
            payload = b"upstream unavailable"
            status = 502
            response_headers = ()
        if len(payload) > MAX_RESPONSE_BYTES:
            payload = b"upstream response exceeded limit"
            status = 502
            response_headers = ()
        duration_ms = min(
            int((time.monotonic() - started) * 1000),
            int(UPSTREAM_TIMEOUT_SECONDS * 1000),
        )
        record(
            self.command,
            self.path.split("?", 1)[0],
            status,
            duration_ms,
            len(body or b""),
            len(payload),
        )
        self.send_response(status)
        for key, value in response_headers:
            if key.lower() not in {"transfer-encoding", "connection", "content-length"}:
                self.send_header(key, value)
        self.send_header("content-length", str(len(payload)))
        self.end_headers()
        if self.command != "HEAD":
            self.wfile.write(payload)

    def do_GET(self):
        path = self.path.split("?", 1)[0]
        if path == "/health":
            self._json(200, {"status": "healthy"})
            return
        if path == "/__deploy/traffic-evidence":
            self._read_logs()
            return
        self._forward()

    def do_HEAD(self):
        self._forward()

    def do_OPTIONS(self):
        self._forward()

    def do_POST(self):
        self._forward()

    def do_PUT(self):
        self._forward()

    def do_PATCH(self):
        self._forward()

    def do_DELETE(self):
        self._forward()

    def log_message(self, format, *args):
        pass


ThreadingHTTPServer(("0.0.0.0", {{ port }}), Handler).serve_forever()
